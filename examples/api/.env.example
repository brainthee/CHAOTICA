# CHAOTICA /api/v1/ example scripts -- configuration template.
#
# Copy this file to ".env" (in this directory or your working directory) and
# fill in the values, OR export the same variables in your shell. Real
# environment variables always take precedence over the .env file.
#
#   cp .env.example .env

# Base API URL. A bare host is fine -- "/api/v1" is appended if missing, and a
# trailing slash is tolerated. Examples:
#   http://localhost:8000/api/v1
#   https://chaotica.example.com
CHAOTICA_API_URL=http://localhost:8000/api/v1

# API token, sent as "Authorization: Token <token>". Required by every script
# except get_token.py. Get one with:
#   python get_token.py
# or on the server:
#   cd app && python manage.py drf_create_token <your-email>
CHAOTICA_API_TOKEN=

# Only used by get_token.py to request a token from credentials.
CHAOTICA_API_USER=
CHAOTICA_API_PASSWORD=

# Set to "false" for self-signed dev certificates. Defaults to true.
CHAOTICA_VERIFY_SSL=true

# Optional page size, passed as ?page_size= (server default 50, max 200).
# Handy for demonstrating pagination: set to 1 and watch iterate() page through.
# CHAOTICA_PAGE_SIZE=

# Optional per-script defaults (all overridable via command-line flags).
# CHAOTICA_UPCOMING_DAYS=30   # upcoming_deliveries.py window
# CHAOTICA_SCHEDULE_DAYS=28   # schedule.py window
# CHAOTICA_USER_ID=           # schedule.py single-user focus
# CHAOTICA_QUAL_DAYS=90       # qual_expiry.py threshold
